# OpenStemNeo — biến môi trường mẫu
# Copy file này thành .env.local và điền giá trị thật

# Giai đoạn MVP chưa cần auth/DB — file này để dùng cho các giai đoạn sau.

# Database (dùng khi thêm Prisma)
# DATABASE_URL="postgresql://user:password@localhost:5432/openstemneo"

# NextAuth (dùng khi thêm auth)
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
