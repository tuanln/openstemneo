# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_or_eyJ...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx_or_eyJ...

# Chỉ dùng cho Supabase CLI (supabase db push / db link)
SUPABASE_DB_PASSWORD=your-database-password
